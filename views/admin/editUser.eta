<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIM - EDIT <%~ it.userName%></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link href="http://fonts.googleapis.com/css?family=IBM+Plex+Sans">
    <link href="http://fonts.googleapis.com/css?family=IBM+Plex+Mono">
</head>
<body>
    <h1 class="title">SIM ADMIN</h1>
    <h2 class="subtitle">Edit User</h2>

    <form action="/users">
        <button class="add" type="submit"><i class="fa fa-arrow-left"></i>Back</button>
    </form>

    <div class="userbox">
        <h1 class="title">Viewing <%~ it.userName%></h1>

        <form action="/editing">
            <table>
                <tr>
                    <th>Name</th>
                    <th>Position</th>
                    <th>Can Edit Stock</th>
                    <th>Is Administrator</th>
                    <th>Actions</th>
                </tr>
                <tr>
                    <td>
                        <input type="hidden" name="id" value=<%~ it.id%>>
                        <input type="text" name="name" id="name" value=<%~ it.userName%>>
                    </td>

                    <td>
                        <select name="position">
                            <option value="0" <%~ it.manager%>>Manager</option>
                            <option value="1" <%~ it.supervisor%>>Supervisor</option>
                            <option value="2" <%~ it.salesAssistant%>>Sales Assistant</option>
                        </select>
                    </td>

                    <td>
                        <select name="canEdit">
                            <option value="true" <%~ it.editTrue%>>True</option>
                            <option value="false" <%~ it.editFalse%>>False</option>
                        </select>
                    </td>

                    <td>
                        <select name="isAdmin" id="isAdmin">
                            <option value="true" <%~ it.adminTrue%>>False</option>
                            <option value="false" <%~ it.adminFalse%>>False</option>
                        </select>
                    </td>

                    <td>
                        <select name="action">
                            <option value="0">None</option>
                            <option value="1">Delete</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <td>
                        <button class="add" type="submit"><i class="fa fa-floppy-o"></i>Save</button>
                    </td>
                </tr>
            </table>
        </form>
    </div>

    <style>
        :root{
            --black: #131515;
            --superDarkGrey: #1B1D1C;
            --veryDarkGrey: #222423;
            --moderatelyDarkGrey: #313330;
            --darkGrey: #62635d;
            --lightGrey: #B0B1A4;
            --white: #FFFFEC;
            --red: #FF3633;
            --orange: #FEA120;
            --yellow: #FCFC73;
            --green: #83D883;
            --blue: #84B1C2;
            --purple: #C185BD;
        }

        body{
            height: 100%;
            width: 99%;
            background-color: var(--black);
            color: var(--white);
            font-family: "IBM Plex Sans", sans-serif;
        }

        .title{
            font-family: "IBM Plex Mono", monospace;
            font-size: 3rem;
            font-weight: 600;
            margin: 0;
            padding: 0;
            text-align: center;
            margin-bottom: 0rem;
            color: var(--white);
        }

        .subtitle{
            font-family: "IBM Plex Mono", monospace;
            font-size: 1.5rem;
            font-weight: 200;
            margin: 0;
            padding: 0;
            text-align: center;
            font-style: italic;
            margin-bottom: 1rem;
        }

        div{
            padding: 1rem;
            margin-top: 1rem;
            border-radius: 0.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;

            background-color: var(--veryDarkGrey);
        }

        button{
            padding: 0.5rem;
            margin-top: 1rem;
            margin-left: 0;
            border-radius: 0.5rem;

            color: var(--white);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
            border: none;
            cursor: pointer;
        }

        form{
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            width: 100%;
            padding: 0;
            margin: 0;
        }

        .add{
            align-self: center;
            background-color: var(--moderatelyDarkGrey);
        }

        i{
            color: var(--white);
            font-size: 1.5rem;
            margin-right: 0.5rem;
        }

        .add i{
            color: var(--green);
        }

        button:hover{
            background-color: var(--darkGrey);
            transition: 0.25s ease-in-out;
        }

        .addProduct i{
            color: var(--green);
        }

        label{
            color: var(--white);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
        }

        select{
            padding: 0.5rem;
            margin-left: 0;
            border-radius: 0.5rem;

            color: var(--black);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
            border: none;
            height: 100%;
            width: 100%;
        }

        input{
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
            padding-left: 0.5rem;
            margin: 0;
            border-radius: 0.5rem;

            color: var(--black);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
            border: none;
            height: 100%;
            width: 95%;
        }

        .removebutton{
            align-self: center;
            background-color: var(--red);
        }

        .userbox{
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        table{
            border-style: none;
            border-collapse: collapse;
            width: 100%;
            table-layout: fixed;
        }

        th{
            padding: 0.5rem;
            text-align: left;
        }

        td{
            padding: 0.5rem;
        }

    </style>

</body>
</html>
