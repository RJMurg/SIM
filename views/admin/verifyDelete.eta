<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIM - DELETING <%~ it.userName%></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link href="http://fonts.googleapis.com/css?family=IBM+Plex+Sans">
    <link href="http://fonts.googleapis.com/css?family=IBM+Plex+Mono">
</head>
<body>

    <div class="remBox">
        <div class="remBoxInt">
            <h1 class="title">Are you sure you want to delete <%~ it.userName%>?</h1>

            <table>
                <tr>
                    <td>
                        <form action="/deleteUser">
                            <input type="hidden" name="id" value=<%~ it.id%>>
                            <button class="removebutton" type="submit">Yes</button>
                        </form>
                    </td>

                    <td>
                        <form action="/users" method="GET">
                            <button class="removebutton" type="submit">No</button>
                        </form>
                    </td>
                </tr>
            </table>
    </div>

    <style>
        :root{
            --black: #131515;
            --superDarkGrey: #1B1D1C;
            --veryDarkGrey: #222423;
            --moderatelyDarkGrey: #313330;
            --darkGrey: #62635d;
            --lightGrey: #B0B1A4;
            --white: #FFFFEC;
            --red: #FF3633;
            --orange: #FEA120;
            --yellow: #FCFC73;
            --green: #83D883;
            --blue: #84B1C2;
            --purple: #C185BD;
        }

        body{
            height: 100%;
            width: 99%;
            background-color: var(--black);
            color: var(--white);
            font-family: "IBM Plex Sans", sans-serif;
        }

        .title{
            font-family: "IBM Plex Mono", monospace;
            font-size: 3rem;
            font-weight: 600;
            margin: 0;
            padding: 0;
            text-align: center;
            margin-bottom: 0rem;
            color: var(--white);
        }

        .subtitle{
            font-family: "IBM Plex Mono", monospace;
            font-size: 1.5rem;
            font-weight: 200;
            margin: 0;
            padding: 0;
            text-align: center;
            font-style: italic;
            margin-bottom: 1rem;
        }

        div{
            padding: 1rem;
            margin-top: 1rem;
            border-radius: 0.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;

            background-color: var(--veryDarkGrey);
        }

        button{
            padding: 0.5rem;
            margin-top: 1rem;
            margin-left: 0;
            border-radius: 0.5rem;

            color: var(--white);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
            border: none;
            cursor: pointer;
        }

        form{
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            width: 100%;
            padding: 0;
            margin: 0;
        }

        .add{
            align-self: center;
            background-color: var(--moderatelyDarkGrey);
        }

        i{
            color: var(--white);
            font-size: 1.5rem;
            margin-right: 0.5rem;
        }

        .add i{
            color: var(--green);
        }

        button:hover{
            background-color: var(--darkGrey);
            transition: 0.25s ease-in-out;
        }

        .addProduct i{
            color: var(--green);
        }

        label{
            color: var(--white);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
        }

        select{
            padding: 0.5rem;
            margin-left: 0;
            border-radius: 0.5rem;

            color: var(--black);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
            border: none;
            height: 100%;
            width: 100%;
        }

        input{
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
            padding-left: 0.5rem;
            margin: 0;
            border-radius: 0.5rem;

            color: var(--black);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
            border: none;
            height: 100%;
            width: 95%;
        }

        .removebutton{
            align-self: center;
            font-size: 2rem;
            font-weight: 600;
            padding: 2rem;
            background-color: var(--red);
        }

        .remBox{
            display: flex;
            flex-direction: column;
            align-items: center;
            background-color: var(--red);
        }

        .remBoxInt{
            background-color: var(--moderatelyDarkGrey);
            width: 95%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;

            border-radius: 0.5rem;
            box-shadow: 0 0 0.5rem 0.125rem inset var(--black);
        }

        table{
            border-style: none;
            border-collapse: collapse;
            width: 100%;
            table-layout: fixed;
        }

        th{
            padding: 0.5rem;
            text-align: left;
        }

        td{
            padding: 0.5rem;
        }

    </style>

</body>
</html>
