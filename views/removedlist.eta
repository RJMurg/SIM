<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIM - REMOVED</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link href="http://fonts.googleapis.com/css?family=IBM+Plex+Sans">
    <link href="http://fonts.googleapis.com/css?family=IBM+Plex+Mono">
</head>
<body>
    <h1 class="title">SIM</h1>
    <h2 class="subtitle">View Removed Products</h2>

    <table class="override">
        <tr>
            <td>
                <form action="/">
                    <button class="add" type="submit"><i class="fa fa-arrow-left"></i>Back</button>
                </form>
            </td>

            <td>
                <form action="/add">
                        <button class="add" type="submit"><i class="fa fa-plus"></i>Add New</button>
                </form>
            </td>
        </tr>
    </table>

    <div class="userbox">

        <table>
            <tr>
                <th>Product Name</th>
                <th>Quantity</th>
                <th>Expiry Date</th>
                <th>Pull Date</th>
                <th>Location</th>
                <th>Removed Date</th>
            </tr>
            <%~ it.data%>
        </table>
    </div>

    <style>
        :root{
            --black: #131515;
            --superDarkGrey: #1B1D1C;
            --veryDarkGrey: #222423;
            --moderatelyDarkGrey: #313330;
            --darkGrey: #62635d;
            --lightGrey: #B0B1A4;
            --white: #FFFFEC;
            --red: #FF3633;
            --orange: #FEA120;
            --yellow: #FCFC73;
            --green: #83D883;
            --blue: #84B1C2;
            --purple: #C185BD;
        }

        body{
            height: 100%;
            width: 99%;
            background-color: var(--black);
            color: var(--white);
            font-family: "IBM Plex Sans", sans-serif;
        }

        .title{
            font-family: "IBM Plex Mono", monospace;
            font-size: 3rem;
            font-weight: 600;
            margin: 0;
            padding: 0;
            text-align: center;
            margin-bottom: 0rem;
            color: var(--white);
        }

        .subtitle{
            font-family: "IBM Plex Mono", monospace;
            font-size: 1.5rem;
            font-weight: 200;
            margin: 0;
            padding: 0;
            text-align: center;
            font-style: italic;
            margin-bottom: 1rem;
        }

        div{
            padding: 1rem;
            margin-top: 1rem;
            border-radius: 0.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;

            background-color: var(--veryDarkGrey);
        }

        button{
            padding: 0.5rem;
            margin-top: 1rem;
            margin-left: 0;
            border-radius: 0.5rem;

            color: var(--white);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
            border: none;
            cursor: pointer;
        }

        form{
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            width: 100%;
            padding: 0;
            margin: 0;
        }

        .add{
            align-self: center;
            background-color: var(--moderatelyDarkGrey);
        }

        i{
            color: var(--white);
            font-size: 1.5rem;
            margin-right: 0.5rem;
        }

        .add i{
            color: var(--green);
        }

        button:hover{
            background-color: var(--darkGrey);
            transition: 0.25s ease-in-out;
        }

        .addProduct i{
            color: var(--green);
        }

        label{
            color: var(--white);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
        }

        select{
            padding: 0.5rem;
            margin-bottom: 0.5rem;
            margin-left: 0;
            border-radius: 0.5rem;

            color: var(--black);
            font-family: "IBM Plex Sans", sans-serif;
            font-size: 1rem;
            font-weight: 400;
            border: none;
        }

        .removebutton{
            align-self: center;
            background-color: var(--red);
        }

        .userbox{
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        table{
            border-radius: 0.5rem;
            border-width: 1px;
            border-color: var(--white);
            border-style: solid;
            border-collapse: collapse;
            width: 100%;
            table-layout: fixed;
        }

        th{
            border-radius: 0.5rem;
            border-width: 1px;
            border-color: var(--white);
            border-style: solid;
            border-collapse: collapse;
            padding: 0.5rem;
            text-align: left;
        }

        td{
            border-radius: 0.5rem;
            border-width: 1px;
            border-color: var(--white);
            border-style: solid;
            border-collapse: collapse;
            padding: 0.5rem;
            text-align: left;
        }

        .override{
            width: 100%;
            margin: 0;
            padding: 0;
            border: none;
        }

        .override td{
            border: none;
            padding: 0;
            margin: 0;
        }

    </style>

</body>
</html>
